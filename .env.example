# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ==========================================
# TURSO DATABASE CREDENTIALS (REQUIRED)
# ==========================================
TURSO_DATABASE_URL="libsql://your-database-url.turso.io"
TURSO_AUTH_TOKEN="your-database-auth-token"

# ==========================================
# GROQ API KEYS (3 DIFFERENT INSTANCES CARED FOR)
# ==========================================
# 1. Main GROQ API Key (For core agent and general LLM interactions)
GROQ_API_KEY=""

# 2. Secondary GROQ API Key (Specifically for handling internal Product Processing / Title Generation)
PRODUCT_GROQ_API_KEY=""

# 3. Third GROQ API Key (Assigned specifically to background Blog Generation and Content logic)
BLOG_GROQ_API_KEY=""

# ==========================================
# APPLICATION SETTINGS
# ==========================================
JWT_SECRET="your_jwt_secret_key_here"
PORT=3000

# ==========================================
# OTHER INTEGRATIONS & AI SERVICES
# ==========================================
GEMINI_API_KEY="MY_GEMINI_API_KEY"
APP_URL="MY_APP_URL"
EXTERNAL_SYNC_KEY="uk-stander-sync-2026"
RAINFOREST_API_KEY=""
IMPROVMX_API_KEY=""
